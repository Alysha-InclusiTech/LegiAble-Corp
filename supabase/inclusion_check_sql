CREATE TABLE public.inclusion_checks (
  id UUID NOT NULL DEFAULT gen_random_uuid() PRIMARY KEY,
  user_id UUID NOT NULL REFERENCES auth.users(id) ON DELETE CASCADE,
  score INTEGER NOT NULL,
  answers JSONB NOT NULL,
  tips JSONB NOT NULL DEFAULT '[]'::jsonb,
  created_at TIMESTAMP WITH TIME ZONE NOT NULL DEFAULT now()
);

ALTER TABLE public.inclusion_checks ENABLE ROW LEVEL SECURITY;

CREATE POLICY "Users can insert their own checks"
ON public.inclusion_checks
FOR INSERT
WITH CHECK (auth.uid() = user_id);

CREATE POLICY "Users can view their own checks"
ON public.inclusion_checks
FOR SELECT
USING (auth.uid() = user_id);

CREATE POLICY "Admins can view all checks"
ON public.inclusion_checks
FOR SELECT
USING (public.has_role(auth.uid(), 'admin'));
